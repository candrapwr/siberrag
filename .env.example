# ============================================================
# SiberRAG - Environment Variables Template
# ============================================================
# Salin file ini menjadi .env lalu isi nilai sesuai kebutuhan.
#   cp .env.example .env
#
# .env TIDAK akan di-commit ke git (sudah di .gitignore).
# API key lebih aman di env var daripada di config.yaml.

# ---- Embedding API (provider openai / custom) ----
# Isi dengan API key provider embedding Anda.
# Contoh provider: OpenAI, DeepInfra, Jina, Cohere, Together, dll.
# Untuk endpoint lokal (Ollama/LM Studio) tanpa auth, biarkan kosong.
OPENAI_API_KEY=

# ---- LLM API (provider openai) ----
# Sama seperti di atas; OPENAI_API_KEY dipakai bersama embedding & LLM.
# Bila endpoint LLM berbeda dengan embedding, gunakan config.yaml (llm.api_base).
